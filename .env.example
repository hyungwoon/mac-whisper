# Mac Whisper LLM refinement API key.
#
# Copy this file to `.env` and fill in your key:
#   cp .env.example .env
#
# `.env` is gitignored. `make run` sources it before launching the app so the
# process inherits the variable. For an installed app (launched from Finder),
# either run once:
#   launchctl setenv MACWHISPER_LLM_API_KEY sk-...
# or place the same line in ~/.config/macwhisper/.env (read at every launch).
MACWHISPER_LLM_API_KEY=
